# ============================================
# BrainBox Core — Configuration
# ============================================
# Copy this file to .env and fill in your API keys.
# All three keys are required for the app to work.

# 1. Anthropic (Claude) — generates answers
#    Get your key: https://console.anthropic.com/settings/keys
#    Free tier: none. Haiku costs ~$0.002/question.
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 2. Google AI (Gemini) — embeddings + fast model + audio transcription
#    Get your key: https://aistudio.google.com/app/apikey
#    Free tier: generous (enough for most personal use)
GOOGLE_API_KEY=AIzaSy-xxxxx

# 3. Pinecone — vector database (stores your document passages)
#    Get your key: https://app.pinecone.io
#    Free tier: 1 index, 100K vectors (plenty to start)
PINECONE_API_KEY=pcsk_xxxxx

# ============================================
# Optional settings (defaults work fine)
# ============================================

# Pinecone index name (created automatically on first run)
PINECONE_INDEX_NAME=brainbox

# Default Claude model (changed at runtime via Settings)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# How documents are split into passages
# Smaller chunks = more precise retrieval, larger = more context per passage
CHUNK_SIZE=500
CHUNK_OVERLAP=50
